# ============================================================
# Medicare Claim Denial Intelligence Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=denial_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=denial_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@denial.local
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# ── Apache Airflow ────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_password_here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
