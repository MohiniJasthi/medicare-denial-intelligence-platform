# Copy to secrets.toml for local testing (secrets.toml is gitignored).
# On Streamlit Cloud: paste into App → Settings → Secrets (do not commit).

# Option A — individual fields (recommended)
POSTGRES_USER = "denial_user"
POSTGRES_PASSWORD = "your_password"
POSTGRES_HOST = "your-db-host.neon.tech"
POSTGRES_PORT = "5432"
POSTGRES_DB = "denial_db"

# Option B — single connection URL (Neon, Supabase, Railway, etc.)
# DATABASE_URL = "postgresql://denial_user:password@host.neon.tech:5432/denial_db?sslmode=require"

# Option C — nested section (also supported)
# [postgres]
# user = "denial_user"
# password = "your_password"
# host = "your-db-host.neon.tech"
# port = "5432"
# database = "denial_db"
